{
  "functions": {
    "api/config.js": { "maxDuration": 5 },
    "api/gcal-token.js": { "maxDuration": 10 },
    "api/push-subscribe.js": { "maxDuration": 10 },
    "api/push-notify.js": { "maxDuration": 30 },
    "api/gemini.js": { "maxDuration": 15 }
  },
  "crons": [
    {
      "path": "/api/push-notify",
      "schedule": "0 15 * * *"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/shop", "dest": "/shop.html" },
    { "src": "/homepage", "dest": "/homepage.html" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
